# ── Scan interval ────────────────────────────────────────────
# How often to run the scraper, in seconds.
# 0 = run once and exit  |  21600 = every 6 h  |  86400 = daily
SCAN_INTERVAL=21600

# ── Ollama (only needed when using the "ollama" profile) ─────
# Set this to http://ollama:11434 when running the ollama compose profile,
# or to your own Ollama server URL when running it externally.
# Then update the Ollama URL field inside olx_scraper.py / GUI config.
OLLAMA_URL=http://ollama:11434
